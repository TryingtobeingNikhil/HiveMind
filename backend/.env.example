# Application
APP_NAME=open-deep-research
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120.0

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Phase 2
TOKENIZER_MODEL=bert-base-uncased
CHROMA_PERSIST_DIR=./data/chroma
DATABASE_PATH=./data/documents.db
UPLOADS_DIR=./data/uploads

# Phase 3
# Set LLM_PROVIDER=groq to use Groq cloud API (recommended for low-RAM machines).
# Set LLM_PROVIDER=ollama to use local Ollama.
LLM_PROVIDER=groq
SKIP_CRITIC_FOR_LOW_COMPLEXITY=True
# Delay between LLM calls — increase if you hit Groq rate limits frequently
LLM_CALL_DELAY_SECONDS=2.0

# Groq (required when LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=60.0
# Retries and wait apply to both network errors AND rate limits (429)
GROQ_MAX_RETRIES=5
GROQ_RETRY_WAIT=15.0

# Phase 4
MAX_RESEARCH_ITERATIONS=2
CONFIDENCE_THRESHOLD=0.5
EVALUATOR_ENABLED=True

# Phase 5
REDIS_URL=redis://localhost:6379/0
SSE_POLL_INTERVAL_SECONDS=1.0
OTEL_ENABLED=False
OTEL_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=open-deep-research
